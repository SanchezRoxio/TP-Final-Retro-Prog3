<%- include("partials/head.ejs") %>
<%- include("partials/nav.ejs") %>

<main class="main-dashboard-post">
    <section class="form-productos">
            <h2>Crear producto</h2>
            <form id="postProduct-form" class="form-alta">
                <label for="nameProd">Nombre</label>
                <input type="text" name="name" id="nameProd" required>
                <label for="imageProd">Imagen</label>
                <input type="text" name="image" id="imageProd" required>
                <label for="categoryProd">Categoria</label>
                <select name="category" id="categoryProd" required>
                        <option>Seleccione un tipo de fichin...</option>
                        <option value="classic">Clásico Retro (80s)</option>
                        <option value="fighting">Lucha / Pelea (90s)</option>
                        <option value="racing">Simulador / Carreras</option>
                </select>
                <label for="priceProd">Precio</label>
                <input type="number" name="price" id="priceProd" required>
                <div>
                    <input type="submit" value="Crear producto">
                </div>
            </form>
    </section>
        

    <!-- Formulario para crear usuario -->
    <section class="form-usuarios">
        <div class="form-container">
            <h2>Crear usuario</h2>
            <form id="postUser-form" class="form-alta">
                <label for="nameUser">Nombre</label>
                <input type="text" name="nameUser" id="nameUser" required>
                <label for="surnameUser">Apellido</label>
                <input type="text" name="surnameUser" id="surnameUser" required>
                <label for="emailUser">Email</label>
                <input type="email" name="emailUser" id="emailUser" required>
                <label for="passwordUser">Password</label>
                <input type="password" name="passwordUser" id="passwordUser" required>
                <div>
                    <input type="submit" value="Crear usuario">
                </div>
            </form>
        </div>
    </section>

</main>

<script src="/js/post.js"></script>
<%- include("partials/footer.ejs") %>